{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "ErgoScript",
    "scopeName": "source.ergoscript",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#context-variables"
        },
        {
            "include": "#types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.ergoscript",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.ergoscript",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.ergoscript",
                    "match": "\\b(if|else|return)\\b"
                },
                {
                    "name": "keyword.other.ergoscript",
                    "match": "\\b(val|def|true|false)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.ergoscript",
                    "match": "\\b(blake2b256|sha256|proveDlog|proveDHTuple|sigmaProp|atLeast|allOf|anyOf|serialize|deserializeTo|byteArrayToBigInt|byteArrayToLong|longToByteArray|getVar|unsignedBigInt)\\b"
                }
            ]
        },
        "context-variables": {
            "patterns": [
                {
                    "name": "variable.language.ergoscript",
                    "match": "\\b(HEIGHT|SELF|INPUTS|OUTPUTS|CONTEXT)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.ergoscript",
                    "match": "\\b(Int|Long|BigInt|UnsignedBigInt|Boolean|Byte|Short|String|Unit|Box|SigmaProp|GroupElement|AvlTree|Header|PreHeader|Context|Coll|Option)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.ergoscript",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.ergoscript",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.ergoscript",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.ergoscript",
                    "match": "(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|\\^|&|\\|)"
                }
            ]
        }
    }
}